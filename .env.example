# Copy this file to .env and fill in your own key.
# .env is git-ignored -- never commit real keys.

# Google Geocoding API key (Section 4 of the project plan).
# Optional: if left blank, the pipeline falls back to an offline
# regex-based address normalizer so the project still runs end-to-end
# without any API key or billing account.
GOOGLE_API_KEY=

# Random seed for reproducible synthetic data generation.
RANDOM_SEED=42
